import cv2
import matplotlib.pyplot as plt
image = cv2.imread(r"C:\mlb internship\flower.jpg")
if image is None:
    print(" image not founf")
    exit()
plt.imshow(image)
plt.title ("BGR image")
plt.axis("off")
plt.show()
hei=image.shape[0]
wid=image.shape[1]
rgbim=image.copy()
for i in range(hei):
    for j in range(wid):
        blue=image[i,j,0]
        green=image[i,j,1]
        red=image[i,j,2]

        rgbim[i,j,0]=red
        rgbim[i,j,0]=green
        rgbim[i,j,0]=blue

plt.imshow(rgbim)
plt.title ("RGB image")
plt.axis("off")
plt.show()





